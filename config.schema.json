{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "budget-sync configuration",
	"type": "object",
	"required": ["vault_path", "rent"],
	"properties": {
		"db_path": {
			"type": "string",
			"description": "Path to SQLite database file",
			"default": "./data/budget-sync.db"
		},
		"vault_path": {
			"type": "string",
			"description": "Absolute path to Obsidian vault"
		},
		"budget_dir": {
			"type": "string",
			"description": "Directory name within vault for budget notes",
			"default": "Budget"
		},
		"provider": {
			"type": "string",
			"enum": ["basiq", "csv", "manual"],
			"description": "Default provider for sync command",
			"default": "basiq"
		},
		"basiq": {
			"type": "object",
			"description": "Basiq CDR API configuration",
			"properties": {
				"user_id": {
					"type": "string",
					"description": "Basiq user ID"
				},
				"api_url": {
					"type": "string",
					"format": "uri",
					"description": "Basiq API base URL",
					"default": "https://au-api.basiq.io"
				}
			},
			"required": ["user_id"]
		},
		"sync": {
			"type": "object",
			"description": "Sync defaults",
			"properties": {
				"default_range_days": {
					"type": "integer",
					"description": "Default number of days to sync",
					"default": 30,
					"minimum": 1
				},
				"auto_snapshot": {
					"type": "boolean",
					"description": "Capture balance snapshots on every sync",
					"default": true
				}
			}
		},
		"rent": {
			"type": "object",
			"description": "Rent calculation configuration",
			"required": [
				"solo_start_date",
				"solo_weekly_amount",
				"shared_roommate_contribution",
				"landlord_patterns",
				"debit_rent_patterns"
			],
			"properties": {
				"solo_start_date": {
					"type": "string",
					"pattern": "^\\d{4}-\\d{2}-\\d{2}$",
					"description": "Date when solo rent started (YYYY-MM-DD)"
				},
				"solo_weekly_amount": {
					"type": "number",
					"description": "Weekly rent amount when living solo",
					"exclusiveMinimum": 0
				},
				"shared_roommate_contribution": {
					"type": "number",
					"description": "Weekly roommate contribution amount",
					"minimum": 0
				},
				"landlord_patterns": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Substring patterns matching landlord credit transactions"
				},
				"debit_rent_patterns": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Regex patterns matching debit rent transactions"
				}
			}
		}
	}
}
