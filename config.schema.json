{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "budget-sync configuration",
	"type": "object",
	"required": ["vault_path", "rent"],
	"properties": {
		"db_path": {
			"type": "string",
			"description": "Path to SQLite database file",
			"default": "./data/budget-sync.db"
		},
		"corpus_dir": {
			"type": "string",
			"description": "Directory for corpus versioned API snapshots",
			"default": "./data/corpus"
		},
		"vault_path": {
			"type": "string",
			"description": "Absolute path to Obsidian vault"
		},
		"budget_dir": {
			"type": "string",
			"description": "Directory name within vault for budget notes",
			"default": "Budget"
		},
		"provider": {
			"type": "string",
			"enum": ["csv", "manual"],
			"description": "Default provider for ingest command",
			"default": "manual"
		},
		"sync": {
			"type": "object",
			"description": "Sync defaults",
			"properties": {
				"default_range_days": {
					"type": "integer",
					"description": "Default number of days to sync",
					"default": 30,
					"minimum": 1
				},
				"auto_snapshot": {
					"type": "boolean",
					"description": "Capture balance snapshots on every sync",
					"default": true
				}
			}
		},
		"anthropic": {
			"type": "object",
			"description": "Anthropic AI configuration for document parsing",
			"properties": {
				"model": {
					"type": "string",
					"description": "AI model to use for document parsing",
					"default": "claude-sonnet-4-20250514"
				},
				"max_tokens": {
					"type": "integer",
					"description": "Maximum tokens for AI response",
					"default": 8192,
					"minimum": 1
				}
			}
		},
		"rent": {
			"type": "object",
			"description": "Rent calculation configuration",
			"required": [
				"solo_start_date",
				"solo_weekly_amount",
				"landlord_patterns",
				"debit_rent_patterns"
			],
			"properties": {
				"solo_start_date": {
					"type": "string",
					"pattern": "^\\d{4}-\\d{2}-\\d{2}$",
					"description": "Date when solo rent started (YYYY-MM-DD)"
				},
				"solo_weekly_amount": {
					"type": "number",
					"description": "Weekly rent amount when living solo",
					"exclusiveMinimum": 0
				},
				"shared_roommate_contribution": {
					"type": "number",
					"description": "Weekly roommate contribution amount",
					"minimum": 0
				},
				"landlord_patterns": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Substring patterns matching landlord credit transactions"
				},
				"debit_rent_patterns": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Regex patterns matching debit rent transactions"
				}
			}
		}
	}
}
